#include <iostream>
using namespace std;

int main(){
    string s;
    cin >> s;
    int l = s.length();
    for(int i = 1; i < (1 << l); i++){
        string comb = "";
        for(int sh = 0; sh < l; sh++){
            if((i & (1 << sh)) > 0)
                comb += s[sh];
        }
        cout << comb << endl;
    }
}
